# Base de datos (en Docker, usar "db" como host en vez de "localhost")
DATABASE_URL=postgresql+asyncpg://techstore_user:techstore_pass@db:5432/techstore_db

# Seguridad (CAMBIAR en producción)
SECRET_KEY=cambiar-esta-clave-en-produccion-generar-con-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (orígenes permitidos del frontend)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Configuración general
APP_NAME=TechStore API
DEBUG=true

# MercadoPago (opcional, si no se configura se usa el modo mock)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
